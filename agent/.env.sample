# Agent config — copy to .env and fill in.

# Casper node RPC (testnet)
CASPER_NODE_URL=https://node.testnet.casper.network
CASPER_CHAIN_NAME=casper-test

# Path to the agent's funded testnet secret key (PEM)
CASPER_SECRET_KEY_PATH=../keys/secret_key.pem

# Deployed YieldOracle package address (package-... or hash-...)
CVO_PACKAGE_HASH=hash-c26ca260dde2e2e5ffcde635807c3420350c0b7ef5fac527691b9674606337a4

# Gas (motes) for a publish deploy
CVO_PUBLISH_GAS=5000000000

# Gas price tolerance (testnet node currently requires 1)
CASPER_GAS_PRICE_TOLERANCE=1

# LLM endpoint (OpenAI-compatible). Defaults to local 9router.
LLM_BASE_URL=http://127.0.0.1:20128/v1
LLM_API_KEY=
LLM_MODEL=kr/claude-sonnet-4.6

# Loop interval in seconds (default 1800 = 30 min)
LOOP_INTERVAL_SECONDS=1800

# Comma-separated DeFi pools to monitor (id:label form), or leave default
POOLS=
